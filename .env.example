# Copy to .env and use these keys for TEST MODE (no real money).
# Get test keys: Razorpay Dashboard → switch to Test Mode → API Keys.
# For production: use Live Mode keys (rzp_live_...) from Dashboard.
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx

# Optional: when deploying without cdn/ folder (e.g. Railway), set this to your
# CDN base URL (no trailing slash). Images at /cdn/... will redirect here.
# Example: Cloudflare R2 public URL.
# CDN_BASE_URL=https://pub-xxxx.r2.dev
